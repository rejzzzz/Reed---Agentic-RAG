# =============================================================================
# Agentic RAG Pipeline Environment Variables
# =============================================================================

# 1. LLM API Keys (Only need the one you select below)
GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# AWS uses standard boto3 env vars: AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_REGION

# 2. System Settings
LLM_PROVIDER=groq
CHROMA_STORAGE_PATH=./data/chroma_db

# 3. LLM Configuration Defaults
ANTHROPIC_MODEL=claude-3-haiku-20240307
AWS_BEDROCK_MODEL=anthropic.claude-3-haiku-20240307-v1:0
GROQ_MODEL=llama3-8b-8192
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434
LLM_TEMPERATURE=0.0

# 4. Document Processing & NLP Settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MIN_CHUNK_SIZE=100
MAX_CHUNK_SIZE=2000
CHUNK_SIMILARITY_THRESHOLD=0.5
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=32
SPACY_MODEL=en_core_web_sm
PROCESSED_DATA_DIR=./data/processed

# 5. Server Configuration
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
API_TITLE="RAG Pipeline API"
API_VERSION="1.0.0"
# Comma-separated list for CORS origins, or "*" for all
CORS_ORIGINS=*

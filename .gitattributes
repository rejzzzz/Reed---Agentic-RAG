# Set default line endings
* text=auto

# Handle large data files with Git LFS (only inside data directory to avoid messing up package.json etc)
data/**/*.json filter=lfs diff=lfs merge=lfs -text
data/**/*.sqlite3 filter=lfs diff=lfs merge=lfs -text
data/**/*.faiss filter=lfs diff=lfs merge=lfs -text
*.pdf filter=lfs diff=lfs merge=lfs -text
*.bin filter=lfs diff=lfs merge=lfs -text
*.pt filter=lfs diff=lfs merge=lfs -text

# Frontend Images
images/* filter=lfs diff=lfs merge=lfs -text
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.svg text
*.gif filter=lfs diff=lfs merge=lfs -text
